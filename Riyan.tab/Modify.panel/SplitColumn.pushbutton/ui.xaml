<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Split Column" Height="480" Width="450"
        WindowStartupLocation="CenterScreen" Background="#0b0b0b">
    <Window.Resources>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="Margin" Value="5,6,5,6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0">
                <TextBlock Text="Split Column" FontWeight="Bold" FontSize="22" Foreground="White" Margin="0,0,0,5" FontFamily="Segoe UI"/>
                <TextBlock Text="Split selected structural columns at chosen levels with custom offsets." 
                           FontSize="12" Foreground="#888888" TextWrapping="Wrap" FontFamily="Segoe UI"/>
            </StackPanel>
            
            <Image x:Name="logo_img" Grid.Column="1" Width="64" Height="64" HorizontalAlignment="Right" Stretch="Uniform"/>
        </Grid>
        
        <Separator Grid.Row="1" Background="#7b2222" Height="1" Margin="0,15,0,15" BorderThickness="0"/>
        
        <StackPanel Grid.Row="2" Margin="0,0,0,15">
            <TextBlock Text="Select Levels &amp; Offsets" FontSize="14" Foreground="#e0e0e0" Margin="0,0,0,8" FontFamily="Segoe UI"/>
            <Rectangle Height="2" Fill="#7b2222" HorizontalAlignment="Left" Width="150"/>
        </StackPanel>
        
        <Border Grid.Row="3" Background="#111111" BorderBrush="#333333" BorderThickness="1" CornerRadius="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="level_lb" Margin="10">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="2,4,2,4">
                                <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Name}" Margin="5,0,10,0" VerticalAlignment="Center" Width="100" FontFamily="Segoe UI" Foreground="#e0e0e0"/>
                                <TextBlock Text="Offset:" Margin="5,0,5,0" VerticalAlignment="Center" Foreground="#aaaaaa" FontSize="12" FontFamily="Segoe UI"/>
                                <TextBox Text="{Binding Offset, Mode=TwoWay}" Width="60" Height="22" Background="#222222" Foreground="White" BorderBrush="#555555" VerticalContentAlignment="Center" Padding="4,0,0,0" FontFamily="Segoe UI"/>
                                <TextBlock Text="mm" Margin="5,0,0,0" VerticalAlignment="Center" Foreground="#777777" FontSize="11" FontFamily="Segoe UI"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
        
        <Grid Grid.Row="4" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <Button x:Name="cancel_button" Grid.Column="1" Content="Cancel" Width="90" Height="32" Margin="0,0,10,0" 
                    Background="#111111" Foreground="#e0e0e0" BorderBrush="#555555" Click="cancel_clicked"/>
            <Button x:Name="split_button" Grid.Column="2" Content="Split Columns" Width="130" Height="32" 
                    Background="#7b2222" Foreground="White" BorderThickness="0" FontWeight="Bold" Click="split_clicked"/>
        </Grid>
    </Grid>
</Window>
