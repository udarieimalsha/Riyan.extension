<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Riyan Export Manager" Height="680" Width="980"
        WindowStartupLocation="CenterScreen"
        Background="Transparent" WindowStyle="None" AllowsTransparency="True"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Primary (accent) button -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"       Value="#802F2D"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Padding"          Value="0"/>
            <Setter Property="FontSize"         Value="11"/>
            <Setter Property="FontWeight"       Value="SemiBold"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Height"           Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#9E3A38"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#661F1D"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#333333"/>
                                <Setter Property="Foreground" Value="#666666"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary (dark) button -->
        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Background"       Value="#1E1E1E"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="BorderBrush"      Value="#2A2A2A"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="0"/>
            <Setter Property="FontSize"         Value="11"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Height"           Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2A2A2A"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#444444"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#151515"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#151515"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#252525"/>
                                <Setter Property="Foreground" Value="#444444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Rounded Dark TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2A2A2A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#444444"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#802F2D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark TextBox -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="#CCCCCC"/>
            <Setter Property="SelectionBrush" Value="#802F2D"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#555555"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#802F2D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark CheckBox -->
        <Style x:Key="DarkCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Dark RadioButton -->
        <Style x:Key="DarkRadio" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,16,0"/>
        </Style>

        <!-- Dark ComboBox with rounded toggle -->
        <ControlTemplate x:Key="DarkComboBoxToggle" TargetType="ToggleButton">
            <Border x:Name="border" Background="#1E1E1E" BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"/>
                    <Path Grid.Column="1" Data="M0,0 L4,4 L8,0 Z" Fill="#888888"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="border" Property="BorderBrush" Value="#444444"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background"         Value="#1E1E1E"/>
            <Setter Property="Foreground"         Value="White"/>
            <Setter Property="BorderBrush"        Value="#2A2A2A"/>
            <Setter Property="BorderThickness"    Value="1"/>
            <Setter Property="Height"             Value="28"/>
            <Setter Property="FontSize"           Value="11"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Template="{StaticResource DarkComboBoxToggle}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <ContentPresenter x:Name="ContentSite"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              IsHitTestVisible="False"
                                              Margin="8,0,24,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="White"/>
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid x:Name="DropDown" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="200">
                                    <Border Background="#1E1E1E" BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="6">
                                        <ScrollViewer>
                                            <StackPanel IsItemsHost="True"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Resources>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Background"   Value="#1E1E1E"/>
                    <Setter Property="Foreground"   Value="White"/>
                    <Setter Property="Padding"      Value="8,4"/>
                    <Setter Property="FontSize"     Value="11"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#802F2D"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#5A2020"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Style.Resources>
        </Style>

        <!-- TabControl and TabItem styling -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="#111111"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="border" Background="Transparent" BorderBrush="Transparent" BorderThickness="0,0,0,2" Margin="0,0,12,0" Padding="0,0,0,4">
                            <ContentPresenter x:Name="contentPresenter" ContentSource="Header" Focusable="False" Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#802F2D"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark DataGrid Style -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#111111"/>
            <Setter Property="RowBackground" Value="#111111"/>
            <Setter Property="AlternatingRowBackground" Value="#151515"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#222222"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="RowHeight" Value="36"/>
            <Setter Property="FontSize" Value="11.5"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#161616"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="BorderBrush" Value="#1E1E1E"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Margin" Value="4,1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridRow">
                        <Border x:Name="DGR_Border" Background="{TemplateBinding Background}" 
                                CornerRadius="6" Margin="0" SnapsToDevicePixels="True">
                            <SelectiveScrollingGrid>
                                <SelectiveScrollingGrid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </SelectiveScrollingGrid.ColumnDefinitions>
                                <SelectiveScrollingGrid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </SelectiveScrollingGrid.RowDefinitions>
                                <DataGridCellsPresenter Grid.Column="1" ItemsPanel="{TemplateBinding ItemsPanel}" 
                                                         SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                <DataGridDetailsPresenter Grid.Column="1" Grid.Row="1" 
                                                           SelectiveScrollingGrid.SelectiveScrollingOrientation="{Binding AreRowDetailsFrozen, ConverterParameter={x:Static SelectiveScrollingOrientation.Vertical}, Converter={x:Static DataGrid.RowDetailsScrollingConverter}, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}" 
                                                           Visibility="{TemplateBinding DetailsVisibility}"/>
                                <DataGridRowHeader Grid.RowSpan="2" SelectiveScrollingGrid.SelectiveScrollingOrientation="Vertical" 
                                                    Visibility="{Binding HeadersVisibility, ConverterParameter={x:Static DataGridHeadersVisibility.Row}, Converter={x:Static DataGrid.HeadersVisibilityConverter}, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"/>
                            </SelectiveScrollingGrid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="DGR_Border" Property="Background" Value="#1E1E1E"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="DGR_Border" Property="Background" Value="#1A1215"/>
                                <Setter TargetName="DGR_Border" Property="BorderBrush" Value="#802F2D"/>
                                <Setter TargetName="DGR_Border" Property="BorderThickness" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#222222" BorderThickness="1" Background="#111111" CornerRadius="12" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="Auto"/> <!-- Tab Headers Area -->
                <RowDefinition Height="*"/>    <!-- Tab Content -->
                <RowDefinition Height="52"/>   <!-- Wizard Navigation Footer -->
            </Grid.RowDefinitions>

            <!-- TITLE BAR -->
            <Grid Grid.Row="0" Background="#121212" MouseLeftButtonDown="TitleBar_MouseDown">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                    <TextBlock Text="—" Foreground="#802F2D" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Riyan Export Manager v1.0" Foreground="#CCCCCC" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
                <Button x:Name="CloseBtn" Content="✕" HorizontalAlignment="Right"
                        Width="44" Height="36" BorderThickness="0" Cursor="Hand"
                        Background="Transparent" Foreground="#666666"
                        Click="CloseBtn_Click" FontSize="12">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#C0272D"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- PROFILE MANAGER (Floats over Tab Headers) -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,2,24,0" Panel.ZIndex="10">
                <TextBlock Text="👤 Profile" Foreground="#888888" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
                <ComboBox x:Name="CmbProfile" Style="{StaticResource DarkComboBox}" Width="150" Margin="0,0,8,0" SelectionChanged="CmbProfile_SelectionChanged"/>
                <Button x:Name="BtnAddProfile" Content="+" Style="{StaticResource SecondaryBtn}" Width="26" Height="26" Margin="0,0,4,0" Click="BtnAddProfile_Click" ToolTip="New Profile"/>
                <Button x:Name="BtnSaveProfile" Content="💾" Style="{StaticResource SecondaryBtn}" Width="26" Height="26" Margin="0,0,4,0" Click="BtnSaveProfile_Click" ToolTip="Save/Edit Profile"/>
                <Button x:Name="BtnDeleteProfile" Content="🗑" Style="{StaticResource SecondaryBtn}" Width="26" Height="26" Click="BtnDeleteProfile_Click" ToolTip="Delete Profile"/>
            </StackPanel>

            <!-- WIZARD WIDGET CONTAINER -->
            <TabControl x:Name="MainTabControl" Grid.Row="1" Grid.RowSpan="2" BorderThickness="0" SelectionChanged="MainTabControl_SelectionChanged">
                
                <!-- TAB 1: SELECTION -->
                <TabItem Header="Selection">
                    <Grid Margin="24,16,24,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- Row 0: Radios & Search -->
                            <RowDefinition Height="Auto"/> <!-- Row 1: File Naming Scheme Area -->
                            <RowDefinition Height="*"/>    <!-- Row 2: Sheet DataGrid -->
                        </Grid.RowDefinitions>

                        <!-- Row 0: Radios & Search -->
                        <Grid Grid.Row="0" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/> <!-- Radios -->
                                <ColumnDefinition Width="Auto"/> <!-- View/Sheet Set text -->
                                <ColumnDefinition Width="Auto"/> <!-- Filter Checkbox + Combo -->
                                <ColumnDefinition Width="Auto"/> <!-- Save Combo -->
                                <ColumnDefinition Width="Auto"/> <!-- Star -->
                                <ColumnDefinition Width="*"/>    <!-- Spacer -->
                                <ColumnDefinition Width="220"/>  <!-- Search -->
                            </Grid.ColumnDefinitions>

                            <!-- Sheets/Views Radio Buttons -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                                <RadioButton x:Name="RbSheets" Content="Sheets" Style="{StaticResource DarkRadio}" IsChecked="True"/>
                                <RadioButton x:Name="RbViews" Content="Views" Style="{StaticResource DarkRadio}" IsEnabled="False"/>
                            </StackPanel>

                            <TextBlock Grid.Column="1" Text="View/Sheet Set" VerticalAlignment="Center" Foreground="#888888" Margin="0,0,8,0" FontWeight="SemiBold"/>

                            <Border Grid.Column="2" Background="#161616" BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="4" Padding="6,2" Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox Content="Filter by V/S Sets" Style="{StaticResource DarkCheckBox}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="▼" Foreground="#666666" FontSize="8" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="0,0,8,0">
                                <ComboBox x:Name="CmbViewSets" Style="{StaticResource DarkComboBox}" Width="120" Margin="0,0,4,0" SelectionChanged="CmbViewSets_SelectionChanged"/>
                                <Button x:Name="BtnSaveViewSet" Content="💾" Style="{StaticResource SecondaryBtn}" Width="26" Height="26" Margin="0,0,4,0" Click="BtnSaveViewSet_Click" ToolTip="Save selected sheets to this Set"/>
                                <Button x:Name="BtnDeleteViewSet" Content="🗑" Style="{StaticResource SecondaryBtn}" Width="26" Height="26" Click="BtnDeleteViewSet_Click" ToolTip="Delete selected Set"/>
                            </StackPanel>

                            <TextBlock Grid.Column="4" Text="☆" Foreground="#C8922A" FontSize="16" VerticalAlignment="Center" Margin="0,0,0,0" ToolTip="Favorites"/>

                            <!-- Live Search Box -->
                            <Grid Grid.Column="6">
                                <TextBox x:Name="TxtSearch" Padding="8,6,24,6" TextChanged="TxtSearch_TextChanged"/>
                                <TextBlock IsHitTestVisible="False" Text="Search..." VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" Foreground="#555555">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=TxtSearch}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Grid>

                        <!-- Sheets DataGrid -->
                        <Border Grid.Row="1" CornerRadius="8" BorderBrush="#222222" BorderThickness="1" ClipToBounds="True">
                            <DataGrid x:Name="GridSheets" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" SelectionMode="Extended" BorderThickness="0">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Width="40">
                                        <DataGridTemplateColumn.Header>
                                            <CheckBox x:Name="CbHeaderSelectAll" Style="{StaticResource DarkCheckBox}" Click="CbHeaderSelectAll_Click" HorizontalAlignment="Center"/>
                                        </DataGridTemplateColumn.Header>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkCheckBox}" HorizontalAlignment="Center" VerticalAlignment="Center" Click="CbSheetSelect_Click"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Width="150" IsReadOnly="True" FontWeight="Bold">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="Sheet Number" FontSize="11" FontWeight="Bold" Foreground="#888888"/>
                                        </DataGridTextColumn.Header>
                                        <DataGridTextColumn.Binding>
                                            <Binding Path="SheetNumber" Mode="OneWay"/>
                                        </DataGridTextColumn.Binding>
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontSize" Value="12"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="Padding" Value="6,0"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Width="*" IsReadOnly="True">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="Sheet Name" FontSize="11" FontWeight="Bold" Foreground="#888888"/>
                                        </DataGridTextColumn.Header>
                                        <DataGridTextColumn.Binding>
                                            <Binding Path="SheetName" Mode="OneWay"/>
                                        </DataGridTextColumn.Binding>
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontSize" Value="12"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="Padding" Value="4,0"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Width="80" IsReadOnly="True">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="Revision" FontSize="11" FontWeight="Bold" Foreground="#888888" HorizontalAlignment="Center"/>
                                        </DataGridTextColumn.Header>
                                        <DataGridTextColumn.Binding>
                                            <Binding Path="Revision" Mode="OneWay"/>
                                        </DataGridTextColumn.Binding>
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontSize" Value="12"/>
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Width="80" IsReadOnly="True">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="Size" FontSize="11" FontWeight="Bold" Foreground="#888888" HorizontalAlignment="Center"/>
                                        </DataGridTextColumn.Header>
                                        <DataGridTextColumn.Binding>
                                            <Binding Path="Size" Mode="OneWay"/>
                                        </DataGridTextColumn.Binding>
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontSize" Value="12"/>
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <!-- Custom File Name Column — Accented Header like ProSheets -->
                                    <DataGridTemplateColumn Width="2.5*" IsReadOnly="True">
                                        <DataGridTemplateColumn.Header>
                                            <Border Background="#1C1410" BorderBrush="#C8922A" BorderThickness="0,0,0,2"
                                                    Padding="6,4" Margin="-8,-4,-8,-4">
                                                <TextBlock Text="Custom File Name" FontSize="11.5" FontWeight="Bold"
                                                           Foreground="#C8922A" VerticalAlignment="Center"/>
                                            </Border>
                                        </DataGridTemplateColumn.Header>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding CustomFileName}" VerticalAlignment="Center" Padding="6,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="FontSize" Value="12.5"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                            <Setter Property="Foreground" Value="#C8922A"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding CustomFileName}" Value="">
                                                                    <Setter Property="Text" Value="Edit filename..."/>
                                                                    <Setter Property="Foreground" Value="#555555"/>
                                                                    <Setter Property="FontStyle" Value="Italic"/>
                                                                    <Setter Property="FontWeight" Value="Normal"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <!-- Bottom Selection Info -->
                        <Grid Grid.Row="2" Margin="0,12,0,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <CheckBox Content="Show only active Sheets/Views" Style="{StaticResource DarkCheckBox}" Margin="0,0,8,0"/>
                                <TextBlock Text="☆" Foreground="#C8922A" FontSize="16" VerticalAlignment="Center" ToolTip="Favorites"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- TAB 2: FORMAT -->
                <TabItem Header="Format">
                    <Grid Margin="24,20,24,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                            <!-- LEFT PANEL: Formats -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="EXPORT FORMATS" Foreground="#555555" FontSize="9" FontWeight="Bold" Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                                    <CheckBox x:Name="CbPDF" Content="PDF" Style="{StaticResource DarkCheckBox}" Margin="0,0,24,0" IsChecked="True" Click="CbFormat_Click"/>
                                    <CheckBox x:Name="CbDWG" Content="DWG" Style="{StaticResource DarkCheckBox}" IsChecked="True" Click="CbFormat_Click"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- RIGHT PANEL: Setups -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="EXPORT SETUPS" Foreground="#555555" FontSize="9" FontWeight="Bold" Margin="0,0,0,12"/>
                                <StackPanel Margin="0,0,0,16">
                                    <TextBlock Text="PDF Print Setting:" Foreground="#888888" FontSize="10" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="CmbPdfSetup" Style="{StaticResource DarkComboBox}"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="DWG Export Setup:" Foreground="#888888" FontSize="10" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="CmbDwgSetup" Style="{StaticResource DarkComboBox}"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                </TabItem>

                <!-- TAB 3: CREATE -->
                <TabItem Header="Create">
                    <Grid Margin="24,16,24,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- Export Directory -->
                            <RowDefinition Height="*"/>    <!-- Queue Grid -->
                            <RowDefinition Height="Auto"/> <!-- Progress reporting -->
                        </Grid.RowDefinitions>

                        <!-- Export Directory Select -->
                        <Grid Grid.Row="0" Margin="0,0,0,16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="EXPORT DIRECTORY" Foreground="#555555" FontSize="9" FontWeight="Bold" Margin="0,0,0,8"/>
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="50"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TxtExportPath" Background="#1E1E1E" Foreground="White" BorderBrush="#2A2A2A" BorderThickness="1" 
                                         Padding="8,6" FontSize="11" Margin="0,0,8,0" IsReadOnly="True" VerticalContentAlignment="Center"/>
                                <Button x:Name="BtnBrowse" Grid.Column="1" Content="..." Style="{StaticResource SecondaryBtn}" Width="42" Height="28" Click="BtnBrowse_Click"/>
                            </Grid>
                        </Grid>

                        <!-- Export Queue Grid -->
                        <Grid Grid.Row="1" Margin="0,0,0,16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="EXPORT QUEUE" Foreground="#555555" FontSize="9" FontWeight="Bold" Margin="0,0,0,8"/>
                            
                            <Border Grid.Row="1" CornerRadius="8" BorderBrush="#222222" BorderThickness="1" ClipToBounds="True">
                                <DataGrid x:Name="GridQueue" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" SelectionMode="Single" BorderThickness="0">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="View/Sheet Number" Binding="{Binding SheetNumber}" Width="150" IsReadOnly="True" FontWeight="Bold"/>
                                        <DataGridTextColumn Header="View/Sheet Name" Binding="{Binding SheetName}" Width="*" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="Format" Binding="{Binding Format}" Width="80" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="Custom File Name" Binding="{Binding TargetFileName}" Width="2.5*" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" IsReadOnly="True">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="Text" Value="Exporting...">
                                                            <Setter Property="Foreground" Value="Gold"/>
                                                        </Trigger>
                                                        <Trigger Property="Text" Value="Done">
                                                            <Setter Property="Foreground" Value="Green"/>
                                                        </Trigger>
                                                        <Trigger Property="Text" Value="Error">
                                                            <Setter Property="Foreground" Value="Red"/>
                                                        </Trigger>
                                                        <Trigger Property="Text" Value="Pending">
                                                            <Setter Property="Foreground" Value="#888888"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                        </Grid>

                        <!-- Progress reporting section -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <!-- ProgressBar styled custom dark-red -->
                            <ProgressBar x:Name="ExportProgressBar" Grid.Column="0" Height="14" Background="#1A1A1A" BorderBrush="#3A3A3A" BorderThickness="1" 
                                         Foreground="#802F2D" Minimum="0" Maximum="100" Value="0" VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <TextBlock x:Name="TxtPercent" Grid.Column="1" Text="Completed 0%" Foreground="#888888" FontSize="11" VerticalAlignment="Center"/>
                        </Grid>
                    </Grid>
                </TabItem>
            </TabControl>

            <!-- STATUS / NAVIGATION BAR -->
            <Border Grid.Row="3" Background="#0E0E0E" BorderBrush="#222222" BorderThickness="0,1,0,0" Padding="12,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Selection Status stats text -->
                    <TextBlock x:Name="StatusTextBlock" Grid.Row="0" Text="0 sheets and 0 views selected. Total: 0" Foreground="#888888" FontSize="11" Margin="0,0,0,6"/>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/> <!-- Feedback Buttons -->
                            <ColumnDefinition Width="*"/>    <!-- Spacer -->
                            <ColumnDefinition Width="Auto"/> <!-- Status Text & Settings -->
                            <ColumnDefinition Width="Auto"/> <!-- Nav Buttons -->
                        </Grid.ColumnDefinitions>
                        
                        <!-- Feedback Buttons -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="Feedback" Background="#00A97E" Foreground="White" BorderThickness="0" Padding="10,4" FontSize="11" FontWeight="Bold" Margin="0,0,8,0">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            <Button Content="Need something unique?" Background="#00A97E" Foreground="White" BorderThickness="0" Padding="10,4" FontSize="11" FontWeight="Bold">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                        
                        <!-- Scheduling assistant & reset Settings -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                            <TextBlock Text="The scheduling assistant is: Off" Foreground="#888888" FontSize="11" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            
                            <Button x:Name="BtnResetSettings" Content="⚙" FontSize="16" Background="Transparent" Foreground="#C8922A" 
                                    BorderThickness="0" Width="28" Height="28" Cursor="Hand" Click="BtnResetSettings_Click" VerticalAlignment="Center" Margin="0,0,4,0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" BorderBrush="#C8922A" BorderThickness="1" CornerRadius="4">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#1A1510"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>

                        <!-- Back & Next Navigation Buttons -->
                        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="BtnBack" Content="Back" Style="{StaticResource SecondaryBtn}" Width="80" Height="32" Margin="0,0,10,0" Click="BtnBack_Click"/>
                            <Button x:Name="BtnNext" Content="Next" Style="{StaticResource PrimaryBtn}" Width="80" Height="32" Click="BtnNext_Click"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
