<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Export Manager" Height="820" Width="1050"
        WindowStartupLocation="CenterScreen"
        Background="#111111" WindowStyle="None" AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <!-- Primary (accent) button -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"       Value="#802F2D"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="FontWeight"       Value="SemiBold"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Height"           Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#9E3A38"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#661F1D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary (dark) button -->
        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Background"       Value="#1E1E1E"/>
            <Setter Property="Foreground"       Value="#CCCCCC"/>
            <Setter Property="BorderBrush"      Value="#3A3A3A"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="FontSize"         Value="11"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Height"           Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2A2A2A"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#555555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tab style -->
        <Style x:Key="DarkTab" TargetType="TabItem">
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="tabBorder" Background="Transparent" BorderBrush="Transparent" BorderThickness="0,0,0,2" Padding="{TemplateBinding Padding}" Cursor="Hand">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="tabBorder" Property="BorderBrush" Value="#802F2D"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="tabBorder" Property="Background" Value="#1A1A1A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Dark ComboBox Toggle -->
        <ControlTemplate x:Key="DarkComboBoxToggle" TargetType="ToggleButton">
            <Border x:Name="border" Background="#1E1E1E" BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="3">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"/>
                    <Path Grid.Column="1" Data="M0,0 L4,4 L8,0 Z" Fill="#888888"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="border" Property="BorderBrush" Value="#666666"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background"         Value="#1E1E1E"/>
            <Setter Property="Foreground"         Value="White"/>
            <Setter Property="BorderBrush"        Value="#3A3A3A"/>
            <Setter Property="BorderThickness"    Value="1"/>
            <Setter Property="Height"             Value="28"/>
            <Setter Property="FontSize"           Value="11"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Template="{StaticResource DarkComboBoxToggle}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <ContentPresenter x:Name="ContentSite"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              IsHitTestVisible="False"
                                              Margin="8,0,24,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="White"/>
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid x:Name="DropDown" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="200">
                                    <Border Background="#1E1E1E" BorderBrush="#3A3A3A" BorderThickness="1">
                                        <ScrollViewer>
                                            <StackPanel IsItemsHost="True"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Resources>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Background"   Value="#1E1E1E"/>
                    <Setter Property="Foreground"   Value="White"/>
                    <Setter Property="Padding"      Value="8,4"/>
                    <Setter Property="FontSize"     Value="11"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#802F2D"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#5A2020"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Style.Resources>
        </Style>

        <!-- DataGrid styling -->
        <Style x:Key="DarkDataGridColumnHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#2A2A2A"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <Style x:Key="DarkDataGridCell" TargetType="DataGridCell">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="BorderBrush" Value="#2A2A2A"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2A2020"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DarkDataGridRow" TargetType="DataGridRow">
            <Setter Property="Background" Value="#141414"/>
            <Setter Property="BorderBrush" Value="#2A2A2A"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E1E1E"/>
                </Trigger>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="#1A1515"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#333333" BorderThickness="1" CornerRadius="2">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>  <!-- Title Bar -->
                <RowDefinition Height="*"/>   <!-- Content -->
                <RowDefinition Height="48"/>  <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- ═══════════ TITLE BAR ═══════════ -->
            <Grid Grid.Row="0" Background="#0E0E0E" MouseLeftButtonDown="TitleBar_MouseDown">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                    <TextBlock Text="⬌" Foreground="#802F2D" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="Bold"/>
                    <TextBlock Text="Riyan" Foreground="#802F2D" FontSize="13" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="Export Manager" Foreground="#CCCCCC" FontSize="13" VerticalAlignment="Center"/>
                    <TextBlock Text="  v1.0" Foreground="#555555" FontSize="10" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Profile section -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,50,0">
                    <TextBlock Text="👤 Profile" Foreground="#888888" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="CmbProfile" Width="140" Style="{StaticResource DarkComboBox}" Height="24"/>
                    <Button x:Name="BtnAddProfile" Content="＋" Width="26" Height="24" Style="{StaticResource SecondaryBtn}" Margin="4,0,0,0" FontSize="14"/>
                    <Button x:Name="BtnDeleteProfile" Content="🗑" Width="26" Height="24" Style="{StaticResource SecondaryBtn}" Margin="4,0,0,0" FontSize="11"/>
                </StackPanel>

                <Button x:Name="CloseBtn" Content="✕" HorizontalAlignment="Right"
                        Width="44" Height="40" BorderThickness="0" Cursor="Hand"
                        Background="Transparent" Foreground="#666666"
                        Click="CloseBtn_Click" FontSize="12">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#C0272D"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- ═══════════ MAIN CONTENT ═══════════ -->
            <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="0">
                <TabControl.Resources>
                    <Style TargetType="TabControl">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabControl">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Border Grid.Row="0" Background="#141414" BorderBrush="#2A2A2A" BorderThickness="0,0,0,1">
                                            <TabPanel IsItemsHost="True" Margin="16,0,0,0"/>
                                        </Border>
                                        <ContentPresenter Grid.Row="1" ContentSource="SelectedContent"/>
                                    </Grid>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <!-- ════════ TAB 1: SELECTION ════════ -->
                <TabItem Header="Selection" Style="{StaticResource DarkTab}">
                    <Grid Margin="20,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- Export Rules -->
                            <RowDefinition Height="Auto"/>  <!-- Set Paper/Orientation -->
                            <RowDefinition Height="*"/>     <!-- DataGrid -->
                        </Grid.RowDefinitions>

                        <!-- Export Rules GroupBox -->
                        <Border Grid.Row="0" BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="4" Padding="16,12" Margin="0,0,0,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="EXPORT RULES" Foreground="#802F2D" FontSize="10" FontWeight="Bold" Margin="0,0,0,10"/>

                                <!-- Folder Selection -->
                                <Grid Grid.Row="1" Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Folder Selection" Foreground="#888888" FontSize="11" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBox x:Name="TxtExportPath" Grid.Column="1" Background="#1E1E1E" Foreground="#CCCCCC" BorderBrush="#3A3A3A" BorderThickness="1"
                                             Padding="6,4" FontSize="11" IsReadOnly="True"/>
                                    <Button x:Name="BtnBrowse" Grid.Column="2" Content="..." Width="30" Style="{StaticResource SecondaryBtn}" Click="BtnBrowse_Click" Margin="6,0,0,0"/>
                                </Grid>

                                <!-- Save Options -->
                                <StackPanel Grid.Row="2">
                                    <RadioButton x:Name="RbSameFolder" Content="Save all files in the same folder location" Foreground="#AAAAAA" FontSize="11" IsChecked="True" Margin="0,0,0,4" GroupName="SaveMode"/>
                                    <RadioButton x:Name="RbSplitByFormat" Content="Save and split files by file format" Foreground="#AAAAAA" FontSize="11" GroupName="SaveMode"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Bulk Actions Row -->
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                            <ComboBox x:Name="CmbSetPaperSize" Style="{StaticResource DarkComboBox}" Width="140" Margin="0,0,8,0">
                                <ComboBoxItem Content="Set Paper Size ▾" IsSelected="True" IsEnabled="False"/>
                                <ComboBoxItem Content="A4 Small"/>
                                <ComboBoxItem Content="A3"/>
                                <ComboBoxItem Content="A2"/>
                                <ComboBoxItem Content="A1"/>
                                <ComboBoxItem Content="A0"/>
                            </ComboBox>
                            <ComboBox x:Name="CmbSetOrientation" Style="{StaticResource DarkComboBox}" Width="150" Margin="0,0,8,0">
                                <ComboBoxItem Content="Set Orientation ▾" IsSelected="True" IsEnabled="False"/>
                                <ComboBoxItem Content="Portrait"/>
                                <ComboBoxItem Content="Landscape"/>
                            </ComboBox>

                            <!-- Select All / Clear -->
                            <Button x:Name="BtnSelectAll" Content="Select All" Width="80" Style="{StaticResource SecondaryBtn}" Margin="16,0,4,0" Click="BtnSelectAll_Click"/>
                            <Button x:Name="BtnClearAll" Content="Clear" Width="60" Style="{StaticResource SecondaryBtn}" Click="BtnClearAll_Click"/>

                            <!-- Progress -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="40,0,0,0">
                                <Border Background="#1E1E1E" BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="3" Padding="10,4" MinWidth="150">
                                    <TextBlock x:Name="TxtProgress" Text="Completed 0%" Foreground="#888888" FontSize="11" VerticalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <!-- DataGrid Sheet Table -->
                        <DataGrid x:Name="SheetDataGrid" Grid.Row="2"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserReorderColumns="False"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#2A2A2A"
                                  Background="#141414"
                                  BorderBrush="#2A2A2A"
                                  BorderThickness="1"
                                  RowBackground="#141414"
                                  AlternatingRowBackground="#181818"
                                  Foreground="#CCCCCC"
                                  FontSize="11"
                                  HeadersVisibility="Column"
                                  SelectionMode="Extended"
                                  SelectionUnit="FullRow"
                                  ColumnHeaderStyle="{StaticResource DarkDataGridColumnHeader}"
                                  CellStyle="{StaticResource DarkDataGridCell}"
                                  RowStyle="{StaticResource DarkDataGridRow}">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="35" Header="✓"/>
                                <DataGridTextColumn Binding="{Binding SheetNumber}" Header="View/Sheet Number" Width="140" IsReadOnly="True"/>
                                <DataGridTextColumn Binding="{Binding SheetName}" Header="View/Sheet Name" Width="*" IsReadOnly="True"/>
                                <DataGridComboBoxColumn Header="Format" Width="80" x:Name="ColFormat">
                                    <DataGridComboBoxColumn.ItemsSource>
                                        <x:Array Type="sys:String" xmlns:sys="clr-namespace:System;assembly=mscorlib">
                                            <sys:String>PDF</sys:String>
                                            <sys:String>DWG</sys:String>
                                            <sys:String>Both</sys:String>
                                        </x:Array>
                                    </DataGridComboBoxColumn.ItemsSource>
                                </DataGridComboBoxColumn>
                                <DataGridTextColumn Binding="{Binding PaperSize}" Header="Size" Width="80"/>
                                <DataGridTextColumn Binding="{Binding Orientation}" Header="Orientation" Width="100"/>
                                <DataGridTextColumn Binding="{Binding CustomFileName}" Header="Custom File Name" Width="*"/>
                                <DataGridTextColumn Binding="{Binding Progress}" Header="Progress" Width="120" IsReadOnly="True"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- ════════ TAB 2: FORMAT ════════ -->
                <TabItem Header="Format" Style="{StaticResource DarkTab}">
                    <Grid Margin="20,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Export Formats -->
                        <Border Grid.Row="0" BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="4" Padding="16,12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="EXPORT FORMATS" Foreground="#802F2D" FontSize="10" FontWeight="Bold" Margin="0,0,0,10"/>
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox x:Name="CbPDF" Content="PDF" Style="{StaticResource DarkCheckBox}" Margin="0,0,24,0" IsChecked="True"/>
                                    <CheckBox x:Name="CbDWG" Content="DWG" Style="{StaticResource DarkCheckBox}" IsChecked="True"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Export Setups -->
                        <Border Grid.Row="1" BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="4" Padding="16,12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="EXPORT SETUPS" Foreground="#802F2D" FontSize="10" FontWeight="Bold" Margin="0,0,0,10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="PDF Print Setting:" Foreground="#888888" FontSize="10" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="CmbPdfSetup" Style="{StaticResource DarkComboBox}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="DWG Export Setup:" Foreground="#888888" FontSize="10" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="CmbDwgSetup" Style="{StaticResource DarkComboBox}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Custom Naming Rule -->
                        <Border Grid.Row="2" BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="4" Padding="16,12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="CUSTOM NAMING RULE" Foreground="#802F2D" FontSize="10" FontWeight="Bold" Margin="0,0,0,10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtNamingRule" Grid.Column="0" Background="#1E1E1E" Foreground="White" BorderBrush="#3A3A3A" BorderThickness="1"
                                             Padding="6,4" FontSize="12" Margin="0,0,8,0" Text="&lt;Sheet Number&gt; - &lt;Sheet Name&gt;"/>
                                    <ComboBox x:Name="CmbInsertTag" Grid.Column="1" Width="130" Style="{StaticResource DarkComboBox}" SelectionChanged="CmbInsertTag_SelectionChanged">
                                        <ComboBoxItem Content="Insert Tag..." IsEnabled="False"/>
                                        <ComboBoxItem Content="Sheet Number"/>
                                        <ComboBoxItem Content="Sheet Name"/>
                                        <ComboBoxItem Content="Project Number"/>
                                        <ComboBoxItem Content="Project Name"/>
                                        <ComboBoxItem Content="Current Revision"/>
                                        <ComboBoxItem Content="Drawn By"/>
                                        <ComboBoxItem Content="Checked By"/>
                                    </ComboBox>
                                </Grid>
                                <TextBlock Text="Preview: A101 - Floor Plan" x:Name="TxtPreview" Foreground="#555555" FontSize="10" Margin="0,6,0,0" FontStyle="Italic"/>
                            </StackPanel>
                        </Border>

                        <!-- Don't Save Report -->
                        <Border Grid.Row="3" BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="4" Padding="16,12" VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="REPORT" Foreground="#802F2D" FontSize="10" FontWeight="Bold" Margin="0,0,0,10"/>
                                <ComboBox x:Name="CmbReport" Style="{StaticResource DarkComboBox}" Width="200" HorizontalAlignment="Left">
                                    <ComboBoxItem Content="Don't Save Report" IsSelected="True"/>
                                    <ComboBoxItem Content="Save as TXT"/>
                                    <ComboBoxItem Content="Save as CSV"/>
                                </ComboBox>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- ════════ TAB 3: CREATE ════════ -->
                <TabItem Header="Create" Style="{StaticResource DarkTab}">
                    <Grid Margin="20,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Scheduling Assistant -->
                        <Border Grid.Row="0" BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="4" Padding="16,12">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <TextBlock Text="SCHEDULING ASSISTANT" Foreground="#802F2D" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="⭐" FontSize="10" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Schedule Toggle -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                    <CheckBox x:Name="CbSchedulePublish" Content="Schedule Publish" Style="{StaticResource DarkCheckBox}" Margin="0,0,16,0"/>
                                    <TextBlock x:Name="TxtScheduleStatus" Text="The Scheduling Assistant is off" Foreground="#666666" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Date / Time / Repeat -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Choose Starting Date" Foreground="#888888" FontSize="10" Margin="0,0,0,4"/>
                                        <Border Background="#1E1E1E" BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="3" Padding="8,4">
                                            <TextBlock x:Name="TxtStartDate" Text="Select date..." Foreground="#CCCCCC" FontSize="11"/>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Choose Time" Foreground="#888888" FontSize="10" Margin="0,0,0,4"/>
                                        <Border Background="#1E1E1E" BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="3" Padding="8,4">
                                            <TextBlock x:Name="TxtStartTime" Text="04:21 PM" Foreground="#CCCCCC" FontSize="11"/>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="Repeat" Foreground="#888888" FontSize="10" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="CmbRepeat" Style="{StaticResource DarkComboBox}" Width="140">
                                            <ComboBoxItem Content="Does not repeat" IsSelected="True"/>
                                            <ComboBoxItem Content="Daily"/>
                                            <ComboBoxItem Content="Weekly"/>
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>

                                <!-- Day Checkboxes -->
                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <CheckBox Content="Mon" Style="{StaticResource DarkCheckBox}" Margin="0,0,12,0"/>
                                    <CheckBox Content="Tue" Style="{StaticResource DarkCheckBox}" Margin="0,0,12,0"/>
                                    <CheckBox Content="Wed" Style="{StaticResource DarkCheckBox}" Margin="0,0,12,0"/>
                                    <CheckBox Content="Thu" Style="{StaticResource DarkCheckBox}" Margin="0,0,12,0"/>
                                    <CheckBox Content="Fri" Style="{StaticResource DarkCheckBox}" Margin="0,0,12,0"/>
                                    <CheckBox Content="Sat" Style="{StaticResource DarkCheckBox}" Margin="0,0,12,0"/>
                                    <CheckBox Content="Sun" Style="{StaticResource DarkCheckBox}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>

            <!-- ═══════════ FOOTER ═══════════ -->
            <Border Grid.Row="2" Background="#0E0E0E" BorderBrush="#222222" BorderThickness="0,1,0,0">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="TxtSheetCount" Text="0 sheets and 0 views selected. Total: 0" Foreground="#888888" FontSize="11" VerticalAlignment="Center"/>

                    <Button x:Name="BtnBack" Grid.Column="1" Content="Back" Width="80" Style="{StaticResource SecondaryBtn}" Margin="0,0,10,0"/>
                    <Button x:Name="RunBtn" Grid.Column="2" Content="Create" Width="100" Style="{StaticResource PrimaryBtn}" Click="RunBtn_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
