<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Task Completed" Height="220" Width="400" WindowStartupLocation="CenterScreen"
        Background="Black" WindowStyle="None" AllowsTransparency="False">
    
    <Window.Resources>
        <!-- Primary Button Style -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#802F2D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#993836"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/> <!-- Title Bar -->
            <RowDefinition Height="*"/>    <!-- Content -->
            <RowDefinition Height="Auto"/> <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- TITLE BAR -->
        <Grid Grid.Row="0" Background="#1A1A1A" MouseLeftButtonDown="TitleBar_MouseDown">
            <TextBlock Text="Notification" Foreground="#BBBBBB" FontSize="11" VerticalAlignment="Center" Margin="15,0,0,0"/>
            <Button x:Name="CloseBtn" Content="✕" HorizontalAlignment="Right" Width="45" Height="32" Background="Transparent" Foreground="#888888" BorderThickness="0" Click="OKButton_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

        <!-- CONTENT -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="25,20,25,0" VerticalAlignment="Top">
            <TextBlock Text="ⓘ" Foreground="#802F2D" FontSize="32" VerticalAlignment="Center" Margin="0,0,20,0"/>
            <TextBlock x:Name="MessageText" Text="Task successfully completed." Foreground="White" FontSize="14" TextWrapping="Wrap" Width="280" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- FOOTER -->
        <Border Grid.Row="2" Background="#0A0A0A" Padding="15">
            <Button x:Name="OKButton" Content="OK" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Right" Width="80" Click="OKButton_Click"/>
        </Border>
    </Grid>
</Window>
