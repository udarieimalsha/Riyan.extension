<Canvas xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="32" Height="32">
    <!-- Maroon Background -->
    <Rectangle Width="32" Height="32" Fill="#802F2D" RadiusX="3" RadiusY="3"/>
    
    <!-- White Crosshair -->
    <!-- Horizontal segments -->
    <Line X1="8" Y1="16" X2="14" Y2="16" Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
    <Line X1="18" Y1="16" X2="24" Y2="16" Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
    <!-- Vertical segments -->
    <Line X1="16" Y1="8" X2="16" Y2="14" Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
    <Line X1="16" Y1="18" X2="16" Y2="24" Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
    
    <!-- Center Dot (Optional but adds precision look) -->
    <Ellipse Canvas.Left="15.5" Canvas.Top="15.5" Width="1" Height="1" Fill="White"/>
</Canvas>
